.Select-button {
    max-height: 100%;
    min-height: 20%;
    width: 80%;
    translate: 0 0;
    font-size: 100px;
}

.ImagePanel {
    flex-grow: 1;
    width: 100%;
    max-height: 65%;
}

.ButtonPanel {
    flex-grow: 1;
    width: 100%;
    align-items: center;
    justify-content: space-around;
    max-height: 35%;
}
